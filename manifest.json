{
	"name": "My Azure Portal Extension",
	"version": "0.4.2",
	"manifest_version": 3,
	"description": "Configure background image on Azure Portal, highlight empty resource groups, and mask your username and Entra ID tenant name",
	"icons": {
		"16": "img/icon16.png",
		"48": "img/icon48.png",
		"128": "img/icon128.png"
	},
	"action": {
		"default_icon": "img/icon128.png",
		"default_popup": "popup.html"
	},
	"permissions": [
		"identity",
		"alarms",
		"storage"
	],
	"host_permissions": [
		"https://login.microsoftonline.com/*",
		"https://management.azure.com/*",
		"https://dc.services.visualstudio.com/*",
		"https://*.in.applicationinsights.azure.com/*"
	],
	"content_scripts": [
		{
			"matches": [
				"https://ms.portal.azure.com/*",
				"https://portal.azure.com/*",
				"https://*.reactblade.portal.azure.net/*",
				"https://*.reactblade-ms.portal.azure.net/*",
				"https://*.reactblade-rc.portal.azure.net/*"
			],
			"js": ["jquery-3.5.1.min.js", "script.js"],
			"run_at": "document_end",
			"all_frames": true
		}
	],
	"background": {
		"service_worker": "background.js",
		"type": "module"
	}
}